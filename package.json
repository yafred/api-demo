{
  "name": "lichess-oauth-app-example",
  "private": true,
  "license": "MIT",
  "scripts": {
    "format": "oxfmt",
    "build": "rollup --config",
    "watch": "rollup --config --watch",
    "dev": "concurrently -k -n chessground,app,server \"pnpm --dir ../chessground exec tsc --sourceMap --declaration --watch\" \"pnpm watch\" \"http-server -c-1\"",
    "prod": "rollup --config --config-prod",
    "serve": "http-server"
  },
  "dependencies": {
    "@bity/oauth2-auth-code-pkce": "^2",
    "bootstrap": "^5",
    "chessground": "../chessground",
    "chessops": "^0.10.5",
    "concurrently": "^9.2.1",
    "page": "^1",
    "snabbdom": "^3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29",
    "@rollup/plugin-node-resolve": "^16",
    "@rollup/plugin-terser": "^1",
    "@rollup/plugin-typescript": "^12",
    "@types/page": "^1",
    "concurrently": "^9.2.1",
    "http-server": "^14",
    "oxfmt": "^0.45.0",
    "rollup": "^4",
    "rollup-plugin-scss": "^3",
    "sass": "^1",
    "tslib": "^2",
    "typescript": "^4"
  },
  "packageManager": "pnpm@10.32.1"
}
